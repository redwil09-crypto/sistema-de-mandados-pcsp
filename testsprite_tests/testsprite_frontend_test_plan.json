[
  {
    "id": "TC001",
    "title": "Save edits to Priority and DP Region successfully from Warrant Detail",
    "description": "Verifies a user can mark a warrant as Priority, change DP Region, confirm the save prompt, and see the updated information persisted on the detail page.",
    "category": "Warrant Detail Edit",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username/email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on the warrant item with ID \"123\" (or the row/link that opens warrant 123 details)"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/warrants/123\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Warrant Details\" is visible"
      },
      {
        "type": "action",
        "description": "Click the Priority control to mark the warrant as Priority"
      },
      {
        "type": "action",
        "description": "Click the DP Region field"
      },
      {
        "type": "action",
        "description": "Type \"Region A\" into the DP Region field"
      },
      {
        "type": "action",
        "description": "Click the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Save changes\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Confirm\" button in the save popup"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Saved successfully\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Region A\" is visible"
      }
    ]
  },
