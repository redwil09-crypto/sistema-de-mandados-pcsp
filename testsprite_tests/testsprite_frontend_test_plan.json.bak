[
  {
    "id": "TC001",
    "title": "Save edits to Priority and DP Region successfully from Warrant Detail",
    "description": "Verifies a user can mark a warrant as Priority, change DP Region, confirm the save flow, and see the updated information persisted on the detail page.",
    "category": "Warrant Detail Edit",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username/email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on the warrant item with ID \"123\" (or the row/link that opens warrant 123 details)"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/warrant-detail/123\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Dossiê Tático\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Priorizar\" button"
      },
      {
        "type": "action",
        "description": "Click the DP Region field"
      },
      {
        "type": "action",
        "description": "Type \"03º DP JACAREÍ\" into the DP Region field"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Alterações Detectadas\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"SINCRONIZAR DADOS\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Alterações salvas com sucesso!\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Prioridade Ativa\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"03º DP JACAREÍ\" is visible"
      }
    ]
  },
  {
    "id": "TC002",
    "title": "Cancel save prompt when attempting to leave with unsaved DP Region changes",
    "description": "Verifies that attempting to navigate away after editing DP Region triggers a save prompt and Cancel keeps the user on the detail page with edits still visible.",
    "category": "Warrant Detail Edit",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username/email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on the warrant item with ID \"123\" (or the row/link that opens warrant 123 details)"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/warrant-detail/123\""
      },
      {
        "type": "action",
        "description": "Click the DP Region field"
      },
      {
        "type": "action",
        "description": "Type \"04º DP JACAREÍ\" into the DP Region field"
      },
      {
        "type": "action",
        "description": "Click on \"Início\" in the floating dock"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Alterações não salvas\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Continuar aqui\" button in the popup"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/warrant-detail/123\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"04º DP JACAREÍ\" is visible"
      }
    ]
  },
  {
    "id": "TC003",
