  {
    "id": "TC005",
    "title": "Priority button toggles state and is persisted after saving",
    "description": "Verifies that clicking 'Priorizar' button updates visible state and remains set after saving.",
    "category": "Warrant Detail Edit",
    "priority": "Medium",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username/email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "action",
        "description": "Click on the warrant item with ID \"123\" (or the row/link that opens warrant 123 details)"
      },
      {
        "type": "action",
        "description": "Click the \"Priorizar\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Prioridade Ativa\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"SINCRONIZAR DADOS\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Alterações salvas com sucesso!\" is visible"
      },
      {
        "type": "action",
        "description": "Click on \"Início\" in the floating dock"
      },
      {
        "type": "action",
        "description": "Click on the warrant item with ID \"123\" (or the row/link that opens warrant 123 details)"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Prioridade Ativa\" is visible"
      }
    ]
  },
  {
    "id": "TC006",
    "title": "Dismiss edits via Escape shortcut keys user on detail page with original state",
    "description": "Verifies that pressing Escape cancels any pending modifications and remains on the same page.",
    "category": "Warrant Detail Edit",
    "priority": "Low",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username/email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "action",
        "description": "Click on the warrant item with ID \"123\" (or the row/link that opens warrant 123 details)"
      },
      {
        "type": "action",
        "description": "Click the DP Region field"
      },
      {
        "type": "action",
        "description": "Type \"Outras Cidades\" into the DP Region field"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Alterações Detectadas\" is visible"
      },
      {
        "type": "action",
        "description": "Press \"Escape\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/warrant-detail/123\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Alterações Detectadas\" is not visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Edições descartadas via atalho (Esc)\" is visible"
      }
    ]
  }
]